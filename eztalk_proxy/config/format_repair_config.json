{
  "enable_format_repair": true,
  "enable_realtime_repair": false,
  "enable_final_repair": true,
  "enable_json_repair": true,
  "enable_math_repair": false,
  "enable_markdown_repair": false,
  "enable_code_repair": false,
  "enable_xml_html_repair": false,
  "enable_structure_repair": false,
  "enable_resume_repair": true,
  "correction_intensity": "light",
  "enable_caching": true,
  "enable_performance_optimization": true,
  "enable_async_processing": false,
  "enable_progressive_correction": true,
  "max_cache_size": 1000,
  "cache_ttl_seconds": 3600,
  "max_processing_time_ms": 5000,
  "chunk_size_threshold": 10000,
  "max_text_length": 100000,
  "math_auto_wrap": false,
  "math_strict_mode": true,
  "math_preserve_spacing": true,
  "inline_math_detection": true,
  "preserve_inline_math_flow": true,
  "avoid_math_forced_newlines": true,
  "smart_math_context_awareness": true,
  "code_auto_language_detection": true,
  "code_preserve_indentation": true,
  "code_fix_incomplete_blocks": true,
  "json_strict_quotes": true,
  "json_remove_trailing_commas": true,
  "json_fix_brackets": true,
  "markdown_fix_headers": true,
  "markdown_fix_lists": true,
  "markdown_fix_links": true,
  "markdown_fix_quotes": true,
  "debug_mode": false,
  "log_repair_actions": true,
  "preserve_original_on_error": true
}